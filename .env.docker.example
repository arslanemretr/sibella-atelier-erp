# Docker stack configuration

WEB_PORT=8080
API_PORT=4001
API_BIND_ADDRESS=127.0.0.1
DB_PORT=5432
DB_BIND_ADDRESS=127.0.0.1

POSTGRES_IMAGE_TAG=16-alpine
POSTGRES_DB=erpsibella
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_VOLUME_NAME=erpsibella_postgres_data
APP_ASSETS_VOLUME_NAME=erpsibella_app_assets
ASSET_STORAGE_PATH=/app/data/assets

# Local example:
# DOCKER_DATABASE_URL=postgresql://postgres:postgres@db:5432/erpsibella
#
# Production example:
# DOCKER_DATABASE_URL=postgresql://app_user:strong-password@db:5432/erpsibella
DOCKER_DATABASE_URL=postgresql://postgres:change-me@db:5432/erpsibella
